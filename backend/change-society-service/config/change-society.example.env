# Service-specific template (same variables as hackathon/.env.example).
# Prefer the root hackathon file: cp hackathon/.env.example hackathon/.env

# --- Model & Qwen Cloud API ---
CHANGE_SOCIETY_MODEL_PROVIDER=qwen
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus
QWEN_TIMEOUT_SECONDS=30
QWEN_MAX_OUTPUT_TOKENS=1400
QWEN_TEMPERATURE=0.1
QWEN_MAX_RETRIES=1
CHANGE_SOCIETY_QWEN_RUN_TOKEN_BUDGET=16000
CHANGE_SOCIETY_ENABLE_LIVE_QWEN_TESTS=0

CHANGE_SOCIETY_ENVIRONMENT=development
CHANGE_SOCIETY_STORE=postgresql
CHANGE_SOCIETY_DATABASE_URL=postgresql://agentcore:replace-me@localhost:32232/agentcore
CHANGE_SOCIETY_CONTEXT_TOKEN_BUDGET=1800
CHANGE_SOCIETY_ALLOWED_ORIGINS=http://localhost:3000
CHANGE_SOCIETY_MANAGED_AGENTS_CONFIG=
CHANGE_SOCIETY_WEBHOOK_AGENT_SECRET=
CHANGE_SOCIETY_WEBHOOK_AGENT_TIMEOUT_SECONDS=30
CHANGE_SOCIETY_API_PORT=32500
