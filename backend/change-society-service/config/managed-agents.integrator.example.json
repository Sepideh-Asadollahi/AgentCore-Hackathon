{
  "contract_version": "1.0",
  "_comment": "Copy to managed-agents.json or set CHANGE_SOCIETY_MANAGED_AGENTS_CONFIG to this file for LangGraph webhook Change Analyst.",
  "agents": [
    {
      "key": "context-scout",
      "name": "Context Scout Worker",
      "provider": "qwen-cloud",
      "adapter_type": "model",
      "role": "context_scout",
      "capabilities": ["retrieve_scoped_project_truth"],
      "description": "In-process Qwen or fake model worker."
    },
    {
      "key": "change-analyst",
      "name": "External Change Analyst (LangGraph)",
      "provider": "langgraph-worker",
      "adapter_type": "webhook",
      "role": "change_analyst",
      "capabilities": ["interpret_ambiguous_software_change"],
      "description": "External LangGraph worker via signed webhook.",
      "endpoint": "http://localhost:32510"
    },
    {
      "key": "impact-analyst",
      "name": "Impact Analyst Worker",
      "provider": "qwen-cloud",
      "adapter_type": "model",
      "role": "impact_analyst",
      "capabilities": ["analyze_cross_boundary_impact"],
      "description": "In-process model worker."
    },
    {
      "key": "policy-guardian",
      "name": "Policy Guardian Worker",
      "provider": "qwen-cloud",
      "adapter_type": "model",
      "role": "policy_guardian",
      "capabilities": ["evaluate_policy_and_approval_risk"],
      "description": "In-process model worker."
    },
    {
      "key": "conflict-judge",
      "name": "Conflict Judge Worker",
      "provider": "qwen-cloud",
      "adapter_type": "model",
      "role": "coordinator_judge",
      "capabilities": ["decompose_route_reconcile"],
      "description": "In-process model worker."
    },
    {
      "key": "frontend-delivery-lead",
      "name": "Frontend Delivery Coordinator",
      "provider": "qwen-cloud",
      "adapter_type": "model",
      "role": "frontend_delivery_lead",
      "capabilities": ["coordinate_frontend_ui_delivery"],
      "description": "In-process model worker."
    }
  ]
}
