# =============================================================================
# Change Society (Qwen Cloud Hackathon — Track 3)
# =============================================================================
# Copy this file to hackathon/.env and fill in your values:
#   cp hackathon/.env.example hackathon/.env
#
# hackathon/.env is gitignored — never commit real API keys or passwords.
# Docs: hackathon/docs/01-quickstart.md, hackathon/docs/03-qwen-cloud-integration.md
# =============================================================================

# -----------------------------------------------------------------------------
# Model & Qwen Cloud API
# -----------------------------------------------------------------------------
# CHANGE_SOCIETY_MODEL_PROVIDER:
#   fake  — default: AgentCore orchestrates only; LangGraph workers call Qwen via webhook
#   qwen  — in-process ModelAgentAdapter (set CHANGE_SOCIETY_MANAGED_AGENTS_CONFIG to managed-agents.model-qwen.inprocess.json)
#
# LangGraph worker (default registry): start with scripts/start-langgraph-demo-stack.sh or Docker Compose.
CHANGE_SOCIETY_MODEL_PROVIDER=fake
CHANGE_SOCIETY_WEBHOOK_AGENT_SECRET=integrator-demo-secret-change-me
AGENTCORE_WEBHOOK_SHARED_SECRET=integrator-demo-secret-change-me
WORKER_PORT=32510
WORKER_LIVE_MODE=1
WORKER_USE_LLM=1
WORKER_RUNTIME_NAME=langgraph-sdk-society-worker
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-flash
QWEN_TIMEOUT_SECONDS=30
QWEN_MAX_OUTPUT_TOKENS=1400
QWEN_TEMPERATURE=0.1
QWEN_MAX_RETRIES=1
# Per society-run token ceiling (0 = unlimited). Helps avoid accidental quota burn.
CHANGE_SOCIETY_QWEN_RUN_TOKEN_BUDGET=40000
# Set to 1 to run pytest live Qwen test when QWEN_API_KEY is present.
CHANGE_SOCIETY_ENABLE_QWEN_ROLE_TOOLS=1
CHANGE_SOCIETY_QWEN_MAX_TOOL_ROUNDS=2
CHANGE_SOCIETY_MCP_TOOL_GATEWAY_URL=

# -----------------------------------------------------------------------------
# Service runtime
# -----------------------------------------------------------------------------
# development | production (production requires qwen + postgresql)
CHANGE_SOCIETY_ENVIRONMENT=development
# Optional: require header X-Judge-Runtime-Secret on POST .../hackathon/dev/judge-runtime-apply (Settings UI)
# CHANGE_SOCIETY_JUDGE_RUNTIME_SECRET=
CHANGE_SOCIETY_STORE=postgresql
# memory | postgresql — demo install uses postgresql when Docker Postgres is started
CHANGE_SOCIETY_CONTEXT_TOKEN_BUDGET=1800
CHANGE_SOCIETY_ALLOWED_ORIGINS=http://localhost:32501,http://127.0.0.1:32501,http://localhost:3000
CHANGE_SOCIETY_API_PORT=32500
# Web UI port (systemd: npm run start). Default 32501; set 3200 only if your firewall exposes that port.
CHANGE_SOCIETY_WEB_PORT=32501
# debug | info | warning — default debug in development for easier demo troubleshooting
CHANGE_SOCIETY_LOG_LEVEL=debug
CHANGE_SOCIETY_MANAGED_AGENTS_CONFIG=
CHANGE_SOCIETY_WEBHOOK_AGENT_TIMEOUT_SECONDS=30

# -----------------------------------------------------------------------------
# PostgreSQL (when CHANGE_SOCIETY_STORE=postgresql)
# -----------------------------------------------------------------------------
CHANGE_SOCIETY_DATABASE_URL=postgresql://agentcore:change-society-dev-local@127.0.0.1:32232/agentcore
AGENTCORE_POSTGRES_DATABASE=agentcore
AGENTCORE_POSTGRES_USER=agentcore
AGENTCORE_POSTGRES_PASSWORD=change-society-dev-local
AGENTCORE_POSTGRES_PORT=32232
AGENTCORE_POSTGRES_HOST=127.0.0.1

CHANGE_SOCIETY_DEMO_AUTO_APPROVE=1

# Frontend (32501). Browser default: same-origin proxy /change-society-api → backend (see frontend/next.config.mjs).
# Set NEXT_PUBLIC_CHANGE_SOCIETY_USE_PROXY=false to call NEXT_PUBLIC_CHANGE_SOCIETY_API_URL directly from the browser.
NEXT_PUBLIC_CHANGE_SOCIETY_API_URL=http://localhost:32500
NEXT_PUBLIC_CHANGE_SOCIETY_PROJECT_ID=demo-project
NEXT_PUBLIC_CHANGE_SOCIETY_TENANT_ID=demo-tenant
NEXT_PUBLIC_CHANGE_SOCIETY_WORKSPACE_ID=demo-workspace

# -----------------------------------------------------------------------------
# Alibaba Cloud (optional — deploy proof & ECS verify)
# -----------------------------------------------------------------------------
# Used by hackathon/deployments/alibaba/deploy-ecs.sh and alibaba_ecs.py (DescribeInstances).
# Configure CLI separately: aliyun configure set --profile default ...
ALIBABA_REGION_ID=
ALIBABA_ECS_INSTANCE_ID=
CHANGE_SOCIETY_RELEASE=

# -----------------------------------------------------------------------------
# Submission notes (optional — for your own Devpost / video checklist)
# -----------------------------------------------------------------------------
# PUBLIC_API_URL=
# GITHUB_REPO_URL=
# DEVPOST_PROJECT_URL=
