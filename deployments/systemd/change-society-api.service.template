[Unit]
Description=Change Society API (AgentCore hackathon)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=@REPO_ROOT@
EnvironmentFile=@REPO_ROOT@/hackathon/.env
Environment=PYTHONPATH=@REPO_ROOT@/hackathon/backend/change-society-service/src
ExecStart=@PYTHON@ -m uvicorn change_society.main:app --host 127.0.0.1 --port 32500
Restart=on-failure
RestartSec=3

[Install]
WantedBy=default.target
