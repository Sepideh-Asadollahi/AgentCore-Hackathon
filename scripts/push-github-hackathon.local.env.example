# Copy to push-github-hackathon.local.env (gitignored). Never commit real tokens here.
#
# GITHUB_REMOTE_URL must be exactly the public AgentCore-Hackathon repo (HTTPS or SSH allowlist).
# GITHUB_REMOTE_URL=https://github.com/Sepideh-Asadollahi/AgentCore-Hackathon.git
# GITHUB_BRANCH=main
# Quote the message so words with hyphens are not treated as shell commands:
# GITHUB_COMMIT_MESSAGE='chore: sync Change Society hackathon submission'
#
# HTTPS auth: by default the script prompts interactively for a Sepideh-Asadollahi PAT
# (hidden input, not saved). Optional non-interactive override:
# GITHUB_TOKEN=ghp_xxxxxxxx   # or GH_TOKEN; must be Sepideh-Asadollahi
